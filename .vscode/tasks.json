{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "auto-push",
      "type": "shell",
      "command": "git add -A && git commit -m \"Auto: save changes\" && git push",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}